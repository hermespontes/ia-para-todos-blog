{
  "provider": "openrouter",
  "primary": "openai/gpt-4o-mini",
  "fallbacks": [
    "meta-llama/llama-3.1-8b-instruct",
    "mistralai/mistral-7b-instruct"
  ],
  "retry": {
    "attempts": 3,
    "backoff_seconds": [1, 2, 5],
    "switch_on": ["timeout", "rate_limit", "5xx", "empty_response", "provider_error"]
  }
}
